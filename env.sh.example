# Example environment configuration for ConnectomeBench.
# Copy to env.sh, fill in the values, then `source env.sh` before running scripts.

# CAVE auth token for MICrONS (mouse) and FlyWire (fly) datastacks.
export CAVE_API_TOKEN="YOUR TOKEN HERE"

# Separate CAVE token for the DAF datastacks (H01 / human, fish1 / zebrafish).
# May be the same value as CAVE_API_TOKEN if your account is provisioned for all four.
export CAVE_API_TOKEN_DAF="YOUR DAF TOKEN HERE"

# Cache directory for intermediate files (Warning: can become large for large datasets)
export CACHE_DIR=".cache"

echo "Exported API tokens."

# Overwrite the .env file with the latest CAVE tokens (read by python-dotenv at runtime)
cat > .env <<EOF
CAVE_API_TOKEN=$CAVE_API_TOKEN
CAVE_API_TOKEN_DAF=$CAVE_API_TOKEN_DAF
CACHE_DIR=$CACHE_DIR
EOF

